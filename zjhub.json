        "name": "rating",
        "request": {
    	"method": "GET",
    	"url": {
    		"raw": "https://api.wmdb.tv/api/v1/movie/search?q={name}&limit=1"
    	}
    },
    "response": {
        "result": "this",
        "data": [
    			{
    				"key": "rating",
    				"value": "doubanRating"
    			}
    		]
        }
    }],
